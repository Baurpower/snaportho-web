# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local automation scratch space and generated exports
/tmp/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Orthobullets BroBot extension build output + locally-captured real page
# fixtures (copyrighted Orthobullets content — manual capture only, never
# committed; see extensions/orthobullets-brobot/README.md)
/extensions/orthobullets-brobot/dist/
/extensions/orthobullets-brobot/.test-dist/
/extensions/orthobullets-brobot/fixtures/ob-review-*.html
*.har
debug-captures/
himalaya-investigation/
