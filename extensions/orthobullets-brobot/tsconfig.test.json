{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".test-dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2022"],
    "types": ["node"],
    "jsx": "preserve"
  },
  "include": ["src/**/*.d.ts", "src/content/**/*.ts", "src/shared/**/*.ts", "src/sidepanel/**/*.ts"]
}
