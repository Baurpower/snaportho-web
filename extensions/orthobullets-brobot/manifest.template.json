{
  "manifest_version": 3,
  "name": "SnapOrtho BroBot Question Tutor",
  "version": "0.1.0",
  "description": "Explain Orthobullets and ROCK question pages with BroBot in a side panel.",
  "permissions": ["storage", "tabs", "activeTab", "sidePanel", "scripting"],
  "host_permissions": [
    "https://www.orthobullets.com/*",
    "https://orthobullets.com/*",
    "https://rock.aaos.org/*",
    "https://www.rock.aaos.org/*",
    "https://*.rock.aaos.org/*",
    "__APP_ORIGIN__/*",
    "https://snaportho.com/*",
    "https://www.snaportho.com/*"
  ],
  "background": {
    "service_worker": "__BACKGROUND_SERVICE_WORKER__",
    "type": "module"
  },
  "icons": {
    "16": "icons/brobot-16.png",
    "32": "icons/brobot-32.png",
    "48": "icons/brobot-48.png",
    "128": "icons/brobot-128.png"
  },
  "side_panel": {
    "default_path": "__SIDEPANEL_HTML__"
  },
  "content_scripts": [
    {
      "matches": ["https://www.orthobullets.com/*", "https://orthobullets.com/*", "https://rock.aaos.org/*", "https://www.rock.aaos.org/*", "https://*.rock.aaos.org/*"],
      "js": ["__CONTENT_SCRIPT__"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open BroBot",
    "default_icon": {
      "16": "icons/brobot-16.png",
      "32": "icons/brobot-32.png",
      "48": "icons/brobot-48.png",
      "128": "icons/brobot-128.png"
    }
  }
}
