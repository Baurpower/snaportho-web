{
  "name": "snaportho-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "extension:orthobullets:build": "node scripts/build-orthobullets-extension.mjs",
    "extension:orthobullets:watch": "./node_modules/.bin/tsc -p extensions/orthobullets-brobot/tsconfig.json --watch",
    "extension:orthobullets:test": "./node_modules/.bin/tsc -p extensions/orthobullets-brobot/tsconfig.test.json && node extensions/orthobullets-brobot/.test-dist/content/extractor.test.js && node extensions/orthobullets-brobot/.test-dist/shared/page-classification.test.js && node --experimental-strip-types src/lib/brobot-anki/url.test.mjs",
    "extension:orthobullets:health-report": "node scripts/report-orthobullets-extraction-health.mjs",
    "anki:audit": "node --experimental-strip-types scripts/import-anki.ts --dry-run",
    "anki:import": "node --experimental-strip-types scripts/import-anki.ts --apply",
    "anki:import:dry-run": "node --experimental-strip-types scripts/import-anki.ts --dry-run",
    "anki:validate": "node --experimental-strip-types scripts/validate-anki-import.ts",
    "anki:kg:map": "node --experimental-strip-types scripts/map-anki-to-kg.ts",
    "kg:auto:loop": "node --experimental-strip-types scripts/run-kg-automation-loop.ts",
    "kg:auto:status": "node --experimental-strip-types scripts/report-kg-automation-status.ts",
    "kg:auto:review-packet": "node --experimental-strip-types scripts/review-kg-automation-packet.ts",
    "kg:auto:approve-packet": "node --experimental-strip-types scripts/approve-kg-automation-packet.ts",
    "kg:auto:approve-batch": "node --experimental-strip-types scripts/approve-kg-automation-batch.ts",
    "kg:auto:apply-approved": "node --experimental-strip-types scripts/apply-approved-kg-automation-proposals.ts",
    "kg:automation:generate": "node --experimental-strip-types scripts/generate-kg-automation-proposals.ts",
    "kg:automation:report": "node --experimental-strip-types scripts/report-kg-automation-proposals.ts",
    "kg:automation:apply-approved": "node --experimental-strip-types scripts/apply-approved-kg-automation-proposals.ts",
    "kg:proof:report": "node --experimental-strip-types scripts/report-next-gen-kg-proof-set.ts",
    "kg:coverage:report": "node --experimental-strip-types scripts/report-kg-canonical-coverage.ts",
    "kg:blocked:prioritize": "node --experimental-strip-types scripts/report-kg-blocked-node-prioritization.ts",
    "kg:blocked:review-llm": "node --experimental-strip-types scripts/review-kg-blocked-node-cohort-with-llm.ts",
    "kg:blocked:cohort": "node --experimental-strip-types scripts/run-kg-blocked-node-cohort.ts",
    "kg:ontology:evidence": "node --experimental-strip-types scripts/build-kg-ontology-evidence-packets.ts",
    "kg:ontology:build-llm": "node --experimental-strip-types scripts/build-kg-ontology-with-llm.ts",
    "kg:retarget:generate": "node --experimental-strip-types scripts/generate-legacy-retargeting-proposals.ts",
    "kg:retarget:apply": "node --experimental-strip-types scripts/apply-legacy-retargeting.ts",
    "kg:retarget:report": "node --experimental-strip-types scripts/report-legacy-retargeting-completion.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@stripe/react-stripe-js": "^3.7.0",
    "@stripe/stripe-js": "^7.4.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.53.0",
    "@tailwindcss/typography": "^0.5.16",
    "branch-sdk": "^2.86.3",
    "canvas-confetti": "^1.9.3",
    "framer-motion": "^12.23.12",
    "globby": "^14.1.0",
    "googleapis": "^171.4.0",
    "jspdf": "^3.0.4",
    "lucide-react": "^0.539.0",
    "next": "15.3.8",
    "openai": "^6.38.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "stripe": "^18.3.0",
    "styled-components": "^6.1.18",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/branch-sdk": "^2.53.7",
    "@types/node": "^20",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/stripe": "^8.0.416",
    "@types/styled-components": "^5.1.34",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "linkedom": "^0.18.12",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.8",
    "typescript": "^5"
  },
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/context/*": [
        "src/context/*"
      ],
      "@/components/*": [
        "src/components/*"
      ],
      "@/lib/*": [
        "src/lib/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ]
}
